Input = 06070180808080807F
ResultBER = Leading zero byte in multibyte OID encoding

# Component encoded as 80 01 - leading zero, should be just 01
Input = 06028001
ResultBER = Leading zero byte in multibyte OID encoding

# Component encoded as 80 7F - leading zero, should be just 7F
Input = 0602807F
ResultBER = Leading zero byte in multibyte OID encoding

