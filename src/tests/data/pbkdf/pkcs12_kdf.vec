# PKCS#12 KDF Test Vectors
#
# SHA-1 and SHA-256 vectors were generated with an independent reference
# implementation (Bouncy Castle
# org.bouncycastle.crypto.generators.PKCS12ParametersGenerator) and
# cross-checked against OpenSSL's PKCS12_key_gen_uni.
#
# Section header encodes algo spec: PKCS12-KDF(hash,id)
#   id 1 = encryption key, 2 = IV, 3 = MAC key

[PKCS12-KDF(SHA-1,1)]

Passphrase = password
Salt = 0A58CF64530D823F
Iterations = 2048
