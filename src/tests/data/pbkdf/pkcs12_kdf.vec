# PKCS#12 KDF Test Vectors
#
# SHA-1 vectors are taken from RFC 7292 Appendix B.4 (the only digest
# enumerated by the RFC). SHA-256 vectors are not part of any IETF spec;
# they were generated with an independent reference implementation
# (Bouncy Castle org.bouncycastle.crypto.generators.PKCS12ParametersGenerator
# configured with SHA-256) and cross-checked against OpenSSL's PKCS12_key_gen_uni.
#
# Section header encodes algo spec: PKCS12-KDF(hash,id)
#   id 1 = encryption key, 2 = IV, 3 = MAC key

[PKCS12-KDF(SHA-1,1)]

Passphrase = password
Salt = 0A58CF64530D823F
Iterations = 2048
Output = 50E8B3F8FB910AFCC54C246374F05F6FC469D0C85AD39E35

Passphrase =
Salt = 02664B0EB6858302
Iterations = 2048
Output = 9175145C6101AE1A738CCE3734E5DC34

Passphrase = test
Salt = 1234567890ABCDEF
Iterations = 1000
Output = 632E2BD7FB28D0F76CE3446B97D73ECB

